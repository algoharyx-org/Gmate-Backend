# Server
NODE_ENV=development
PORT=4000

# Database
DB_URL=mongodb+srv://your-username:your-password@cluster.xxxxx.mongodb.net/gmate

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=10m

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=GMATE <your-email@gmail.com>

# App
APP_NAME=GMATE

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx
ALLOWED_COMPRESSION_TYPES=zip,rar,7z,tar,gz

# Cron Jobs
OVERDUE_CRON_SCHEDULE=*/15 * * * *
